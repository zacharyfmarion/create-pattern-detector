# Copy values into your shell environment before scraping.
# Do not commit real keys.

# Preferred for CPOogle Google Drive downloads.
GOOGLE_DRIVE_API_KEY=

# Optional fallback used by Drive downloads and Gemini if the specific vars are unset.
GOOGLE_API_KEY=

# Optional, only needed if running --gemini-mode review/accepted-review/all
# without using GOOGLE_API_KEY.
GEMINI_API_KEY=
